---
// src/components/BootLoader.astro
---
<div id="boot-loader" class="fixed-fullscreen">
  <div class="tui-text">
    <div class="log-line" style="animation-delay: 0.1s;"><span class="green">[ OK ]</span> Loading NixOS environment...</div>
    <div class="log-line" style="animation-delay: 0.3s;"><span class="green">[ OK ]</span> Mounting file systems...</div>
    <div class="log-line" style="animation-delay: 0.6s;"><span class="green">[ OK ]</span> Starting network manager...</div>
    <div class="log-line" style="animation-delay: 0.8s;"><span class="green">[ OK ]</span> Initializing shellfolio daemon...</div>
    <div class="log-line" style="animation-delay: 1.1s;"><span class="green">[ OK ]</span> Reached target Graphical Interface.</div>
  </div>
</div>

<script is:inline>
  if (sessionStorage.getItem('shellfolioBooted')) {
    document.documentElement.classList.add('skip-loader');
  } else {
    sessionStorage.setItem('shellfolioBooted', 'true');

    // Pega a última linha do log para saber quando a animação inteira acabou
    const lastLogLine = document.querySelector('.log-line:last-child');

    if (lastLogLine) {
      // Quando a animação CSS da última linha terminar, aplicamos o fade out
      lastLogLine.addEventListener('animationend', () => {
        // Um pequeno delay extra (400ms) só pra o usuário ler a última linha
        setTimeout(() => {
          document.documentElement.classList.add('boot-complete');
        }, 400);
      });
    } else {
      // Fallback de segurança absoluto caso o JS não ache o elemento
      setTimeout(() => document.documentElement.classList.add('boot-complete'), 2000);
    }
  }
</script>

<style>
  .fixed-fullscreen {
    position: fixed; inset: 0; background: var(--bg-crust); z-index: 9999;
    /* Removido o padding e o alinhamento central */
    padding: 4px 8px;
  }

  .tui-text { font-family: var(--font-tui); color: var(--text-muted); }
  .green { color: var(--accent-green); font-weight: bold; }

  .log-line {
    opacity: 0;
    animation: popIn 0.1s step-end forwards;
    margin-bottom: 0.3rem;
    line-height: 1.5;
  }

  @keyframes popIn {
    to { opacity: 1; }
  }
</style>
