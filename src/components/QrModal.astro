---
const { id, title, qrImage } = Astro.props;
---
<button onclick={`document.getElementById('${id}').showModal()`} class="modal-btn">
  {title}
</button>

<dialog id={id} class="qr-dialog">
  <div class="dialog-content">
    <h3>{title}</h3>
    <img src={qrImage} alt={`QR Code for ${title}`} loading="lazy" />
    <button onclick={`document.getElementById('${id}').close()`}>Close [x]</button>
  </div>
</dialog>

<style>
  .qr-dialog::backdrop {
    background: rgba(17, 17, 27, 0.8);
    backdrop-filter: blur(2px);
  }
  .qr-dialog {
    background: var(--bg-base);
    color: var(--text-main);
    border: 1px solid var(--accent-green);
    border-radius: 8px;
    padding: 1rem;
  }
  .modal-btn {
    background: none;
    border: none;
    color: var(--accent-amber);
    font-family: var(--font-tui);
    cursor: pointer;
    text-decoration: underline;
    padding: 0;
    margin-right: 1rem;
  }
  .modal-btn:hover { opacity: 0.8; }
</style>
