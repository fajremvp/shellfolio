---
// src/components/AsciiFace.astro
import { siteConfig } from '../config/site.config';
---
<pre class="ascii-art">
{siteConfig.asciiArt}
</pre>

<style>
  .ascii-art {
    color: var(--accent-green);
    white-space: pre;
    font-size: 7px; /* Tente usar pixels cravados se a fonte borrar */
    line-height: 1.1; /* Fontes de hardware costumam preferir line-height 1 */
  }
  @media (min-width: 768px) {
    .ascii-art { font-size: 10.45px; }
  }
</style>
