---
import Prompt from '../Prompt.astro';
import type { Skill } from '../../data/shellfolio';
const { skills } = Astro.props;
---
<section>
  <Prompt cmd="cat /etc/stack.conf" />
  <div class="tui-list prose-list">
    {skills.map((skill: Skill) => (
      <div class="list-item" style="align-items: flex-start;">
        <span class="folder" style="flex: 0 0 39ch;">[{skill.category}]</span>
        <span style="color: var(--text-muted);">{skill.items}</span>
      </div>
    ))}
  </div>
</section>
