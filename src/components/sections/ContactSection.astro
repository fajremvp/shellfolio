---
import Prompt from '../Prompt.astro';
import { contactLinks } from '../../data/shellfolio';
---
<section>
  <Prompt cmd="curl https://contact.local" />
  <div class="tui-grid">
    {contactLinks.map((contact) => (
       <>
         <span class="file">{contact.protocol}</span>
         {contact.url ? (
           <a href={contact.url} target="_blank" rel="noopener noreferrer" class="hover-link" style="color: var(--text-muted); font-family: var(--font-prose); font-size: 1.15rem; word-break: break-all;">{contact.handle}</a>
         ) : (
           <span style="color: var(--text-muted); font-family: var(--font-prose); font-size: 1.15rem; word-break: break-all;">{contact.handle}</span>
         )}
       </>
    ))}
  </div>
</section>
