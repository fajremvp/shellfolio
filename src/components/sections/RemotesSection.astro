---
import Prompt from '../Prompt.astro';
import type { Remote } from '../../data/shellfolio';
const { remotes } = Astro.props;
---
<section>
  <Prompt cmd="git remote -v" />
  <div class="tui-grid">
    {remotes.map((remote: Remote) => (
       <>
         <span class="file">{remote.name}</span>
         <a href={remote.webLink} target="_blank" rel="noopener noreferrer" class="hover-link" style="color: var(--text-muted); font-family: var(--font-prose); font-size: 1.15rem; word-break: break-all;">{remote.url} (fetch)</a>
       </>
    ))}
  </div>
</section>
