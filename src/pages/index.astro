---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import BootLoader from '../components/BootLoader.astro';
import FastfetchHero from '../components/FastfetchHero.astro';
---
<Layout title="fajre@portfolio:~">
  <BootLoader />

  <main class="container">
    <FastfetchHero />

    <section class="content-section">
      <h2>Projetos Recentes</h2>
      <p>Em breve...</p>
    </section>
  </main>
</Layout>

<style>
  .container {
    /* 100% da largura, sem limitação de tamanho e sem centralização */
    width: 100%;
    padding: 4px 8px;
  }

  .content-section {
    margin-top: 3rem;
  }
</style>
