---
// src/pages/index.astro
// Este arquivo existe APENAS para redirecionar o visitante
import { siteConfig } from '../config/site.config';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{siteConfig.title}</title>

  <noscript>
    <meta http-equiv="refresh" content="0;url=/en/" />
  </noscript>

  <style>
    /* Estilo mínimo só pra tela não ficar branca durante os milissegundos do redirect */
    body { background-color: #000000; color: #4af626; font-family: monospace; padding: 1rem; }
  </style>
</head>
<body>

  <script is:inline>
    // Detecta idioma. navigator.language é o padrão moderno. fallback pro userLanguage do IE (legado).
    const userLang = navigator.language || navigator.userLanguage;

    // Pega as primeiras duas letras (ex: "pt-BR" -> "pt")
    const baseLang = userLang.toLowerCase().substring(0, 2);

    // Redireciona imediatamente sem deixar rastro no histórico do botão "Voltar" do navegador
    if (baseLang === 'pt') {
      window.location.replace('/pt');
    } else {
      window.location.replace('/en');
    }
  </script>
</body>
</html>
