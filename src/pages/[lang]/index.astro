---
// src/pages/[lang]/index.astro
import Layout from '../../layouts/Layout.astro';
import BootLoader from '../../components/BootLoader.astro';
import FastfetchHero from '../../components/FastfetchHero.astro';
import Prompt from '../../components/Prompt.astro';
import { data } from '../../data/portfolio';
import { data, contactLinks, paymentMethods } from '../../data/portfolio';
import QrModal from '../../components/QrModal.astro'; // Importe o Modal

// O Astro vai compilar isso em /pt/index.html e /en/index.html
export function getStaticPaths() {
  return [
    { params: { lang: 'pt' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = data[lang as keyof typeof data];
---
<Layout title="fajre@portfolio:~">
  <BootLoader />
  <main class="container">

    <FastfetchHero profile={t.profile} />

    <section>
      <Prompt cmd="cat ~/README.md" />
      <div class="prose">{t.profile.about}</div>
    </section>

    <section>
      <Prompt cmd="ls -l ~/Experiences/" />
      <div class="tui-list">
        {t.experiences.map((exp) => (
          <details class="tui-details">
            <summary class="list-item">
              <span class="indicator"></span>
              <span class="perms">{exp.perms}</span>
              <span class="date">{exp.date}</span>
              <span class="file">{exp.company}</span>
              <span class="text-muted">({exp.format})</span>
              <span class="folder">{exp.folder}</span>
            </summary>
            <div class="expanded-content prose">{exp.content}</div>
          </details>
        ))}
      </div>
    </section>

    <section>
      <Prompt cmd="ls -l ~/Projects/" />
      <div class="tui-list">
        {t.projects.map((proj) => (
          <details class="tui-details">
            <summary class="list-item">
              <span class="indicator"></span>
              <span class="perms">{proj.perms}</span>
              <span class="file">{proj.file}</span>
            </summary>
            <div class="expanded-content prose">{proj.content}<br /><br /><span class="text-muted">>> </span><a href={proj.link} target="_blank" class="hover-link" style="color: var(--text-muted); font-family: var(--font-prose); display: inline-block;">{t.ui.repoLink}</a></div>
          </details>
        ))}
      </div>
    </section>

    <section>
      <Prompt cmd="ls -l ~/Education/" />
      <div class="tui-list">
        {t.education.map((edu) => (
          <details class="tui-details">
            <summary class="list-item">
              <span class="indicator"></span>
              <span class="perms">{edu.perms}</span>
              <span class="date">{edu.date}</span>
              <span class="file">{edu.institution}</span>
              <span class="text-muted">({edu.format})</span>
              <span class="folder">{edu.folder}</span>
            </summary>
            <div class="expanded-content prose">{edu.content}</div>
          </details>
        ))}
      </div>
    </section>

    <section>
      <Prompt cmd="cat /etc/stack.conf" />
      <div class="tui-list prose-list">
        {t.skills.map((skill) => (
          <div class="list-item" style="align-items: flex-start;">
            <span class="folder" style="flex: 0 0 39ch;">[{skill.category}]</span>
            <span class="file">{skill.items}</span>
          </div>
        ))}
      </div>
    </section>

    <section>
      <Prompt cmd="git remote -v" />
      <div class="tui-list">
        {t.remotes.map((remote) => (
           <div class="list-item" style="align-items: flex-start;">
             <span class="file" style="flex: 0 0 10ch; color: var(--text-main); font-family: var(--font-tui);">{remote.name}</span>

             <a href={remote.webLink} target="_blank" class="hover-link" style="color: var(--text-muted); font-family: var(--font-prose); font-size: 1.15rem; word-break: break-all; display: inline-block;">{remote.url} (fetch)</a>
           </div>
        ))}
      </div>
    </section>

    <section>
      <Prompt cmd="curl https://contact.fajre" />
      <div class="tui-list">
        {contactLinks.map((contact) => (
           <div class="list-item" style="align-items: flex-start;">
             <span class="file" style="flex: 0 0 10ch; color: var(--text-main); font-family: var(--font-tui);">{contact.protocol}</span>

             <a href={contact.url} target="_blank" class="hover-link" style="color: var(--text-muted); font-family: var(--font-prose); font-size: 1.15rem; word-break: break-all; display: inline-block;">{contact.handle}</a>
           </div>
        ))}
      </div>
    </section>

    <section>
      <Prompt cmd="cat ~/.wallets.conf" />
      <div class="tui-list">
        {paymentMethods.map((payment) => (
          <details class="tui-details">
            <summary class="list-item" style="align-items: flex-start;">
              <span class="indicator"></span>
              <span class="file" style="flex: 0 0 12ch; color: var(--text-main); font-family: var(--font-tui);">{payment.name}</span>
              <span class="text-muted" style="font-family: var(--font-prose); font-size: 1.15rem;">[ Expand to view ]</span>
            </summary>

            <div class="expanded-content prose" style="display: flex; flex-direction: column; gap: 1rem; max-width: 300px;">
              <img src={payment.qr} alt={`QR Code ${payment.name}`} style="width: 100%; border: 2px dashed var(--text-muted); padding: 4px;" loading="lazy" />

              <div style="font-family: var(--font-prose); font-size: 1.15rem; color: var(--text-muted); word-break: break-all; text-align: left; line-height: 1.4; user-select: text; white-space: normal;">{payment.address}</div>
            </div>
          </details>
        ))}
      </div>
    </section>

    <section>
      <Prompt cmd="locale -a" />
      <div class="tui-list">
        <div class="list-item" style="align-items: flex-start;">
          <span class="file" style="flex: 0 0 12ch; color: var(--text-main); font-family: var(--font-tui);">en_US.utf8</span>
          {lang === 'en' ? (
            <span style="color: var(--text-main); font-family: var(--font-prose); font-size: 1.15rem; font-weight: bold;">{t.ui.langEn}</span>
          ) : (
            <a href="/en" class="hover-link" style="color: var(--text-muted); font-family: var(--font-prose); font-size: 1.15rem;">{t.ui.langEn}</a>
          )}
        </div>
        <div class="list-item" style="align-items: flex-start;">
          <span class="file" style="flex: 0 0 12ch; color: var(--text-main); font-family: var(--font-tui);">pt_BR.utf8</span>
          {lang === 'pt' ? (
            <span style="color: var(--text-main); font-family: var(--font-prose); font-size: 1.15rem; font-weight: bold;">{t.ui.langPt}</span>
          ) : (
            <a href="/pt" class="hover-link" style="color: var(--text-muted); font-family: var(--font-prose); font-size: 1.15rem;">{t.ui.langPt}</a>
          )}
        </div>
      </div>
    </section>

    <div class="final-prompt" style="margin-top: 2rem;">
       <Prompt showCursor={true} />
    </div>

  </main>

  </Layout>

<style>
  .container { width: 100%; padding: 1rem 8px; }
  .final-prompt :global(.prompt-line) {
    margin-bottom: 0;
  }
  .prose { font-family: var(--font-prose); color: var(--text-muted); width: 100%; font-size: 1.15rem; line-height: 1.6; word-wrap: break-word; overflow-wrap: break-word; white-space: pre-wrap; }
  .tui-list { font-family: var(--font-tui); display: flex; flex-direction: column; gap: 0.8rem; font-size: 0.85rem; }
  .prose-list {
    font-family: var(--font-prose);
    font-size: 1.15rem; /* Iguala ao tamanho do AboutMe */
    line-height: 1.6;
  }
  .list-item { display: flex; gap: 1.5rem; color: var(--text-muted); line-height: 1.4; }
  .tui-details { & summary::-webkit-details-marker { display: none; } }
  .tui-details summary { list-style: none; cursor: pointer; user-select: none; transition: opacity 0.2s; }
  .tui-details summary:hover { opacity: 0.8; }
  .indicator::before { content: '[+]'; color: var(--text-muted); margin-right: 0.5rem; font-family: var(--font-tui); }
  .tui-details[open] .indicator::before { content: '[-]'; color: var(--accent-amber); }
  .expanded-content { padding-left: 3rem; margin-top: 0.8rem; margin-bottom: 1.5rem; border-left: 1px dashed var(--text-muted); margin-left: 1rem; }
  .hover-link { text-decoration: none; }
  .hover-link:hover { text-decoration: underline; color: var(--accent-amber); }
  .perms { color: var(--text-main); }
  .folder { color: var(--accent-green); font-weight: bold; }
  .file { color: var(--text-main); }
  @media (max-width: 600px) { .list-item { gap: 0.8rem; font-size: 0.9rem; } }
</style>
